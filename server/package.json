{
  "name": "care-api",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "author": "Pedro Ricardo de Almeida <dev.pedroricardo@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev:api": "tsx watch api-service/index.ts",
    "dev:mqtt": "tsx watch mqtt-service/index.ts",
    "dev": "concurrently --names \"api,mqtt\" --prefix-colors \"cyan,magenta\" \"yarn dev:api\" \"yarn dev:mqtt\"",
    "build": "npx rimraf dist && tsc",
    "start:api": "tsx api-service/index.ts",
    "start:mqtt": "tsx mqtt-service/index.ts",
    "lint": "eslint src/**/*.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prebuild:dev": "npm run lint && npm run test",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx shared/db/seed.ts"
  },
  "dependencies": {
    "@langchain/community": "^1.1.25",
    "@langchain/core": "^1.1.36",
    "@langchain/ollama": "^1.2.6",
    "@langchain/textsplitters": "^1.0.1",
    "@libsql/client": "^0.17.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "langchain": "^1.2.37",
    "mqtt": "^5.15.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.4.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "morgan": "^1.10.1",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
