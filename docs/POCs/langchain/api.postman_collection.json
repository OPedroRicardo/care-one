{
  "info": {
    "name": "RAG Chat API",
    "description": "API de chat com RAG (Retrieval-Augmented Generation) usando LangChain e Chroma DB",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Check API Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["status"]
            },
            "description": "Verifica se a API está funcionando"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Upload Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has collectionName\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('collectionName');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Arquivo PDF para indexar"
                },
                {
                  "key": "collectionName",
                  "value": "rh_policies",
                  "type": "text",
                  "description": "Nome da coleção no Chroma DB"
                },
                {
                  "key": "category",
                  "value": "RH",
                  "type": "text",
                  "description": "Categoria do documento (opcional)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/upload",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "upload"]
            },
            "description": "Faz upload de um PDF e indexa no Chroma DB"
          },
          "response": []
        },
        {
          "name": "List Collections",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/collections",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "collections"]
            },
            "description": "Lista todas as coleções de documentos disponíveis"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Message (New Conversation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has conversationId\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('conversationId');",
                  "    pm.expect(jsonData).to.have.property('response');",
                  "    ",
                  "    // Salvar conversationId para próximas requisições",
                  "    pm.collectionVariables.set('conversationId', jsonData.conversationId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Quantos dias de férias eu tenho direito?\",\n  \"collectionName\": \"rh_policies\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/message",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "message"]
            },
            "description": "Inicia uma nova conversa. O conversationId é gerado automaticamente."
          },
          "response": []
        },
        {
          "name": "Send Message (Continue Conversation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"E como faço para solicitar?\",\n  \"collectionName\": \"rh_policies\",\n  \"conversationId\": \"{{conversationId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/message",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "message"]
            },
            "description": "Continua uma conversa existente usando o conversationId"
          },
          "response": []
        },
        {
          "name": "Send Message (Out of Scope)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Qual a melhor receita de pizza?\",\n  \"collectionName\": \"rh_policies\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/message",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "message"]
            },
            "description": "Testa uma pergunta fora do escopo permitido"
          },
          "response": []
        },
        {
          "name": "Get Conversation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chat/{{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "{{conversationId}}"]
            },
            "description": "Recupera o histórico completo de uma conversa"
          },
          "response": []
        },
        {
          "name": "Delete Conversation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/chat/{{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "{{conversationId}}"]
            },
            "description": "Deleta o histórico de uma conversa"
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ]
}